{
    "compilerOptions": {
        "target": "ES2022",
        "module": "esnext",
        "noEmit": true,
        "moduleResolution": "bundler",
        "lib": [
            "ES2022"
        ],
        "types": [
            "node"
        ],
        "outDir": "./dist",
        "rootDir": ".",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "strict": true,
        // "noUnusedLocals": true,
        // "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "exactOptionalPropertyTypes": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    },
    "include": [
        "src/**/*",
        "tests/**/*",
        "examples/**/*",
        "scripts/**/*",
        "data/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}