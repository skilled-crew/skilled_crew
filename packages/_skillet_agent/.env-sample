# Google OAuth 2.0 credentials for "Sign in with Google" on the web site.
# Created in Google Cloud Console under the "maat-news" project:
# https://console.cloud.google.com/apis/credentials?chat=true&project=maat-news
#
# These are used by passport-google-oauth20 in packages/_skillet_webclient/src/api_routes/api_auth.ts.
# If either variable is missing, Google OAuth is gracefully disabled and only local
# email/password auth remains available.
#
# GOOGLE_CLIENT_ID  — Public identifier sent to Google so it knows which app is requesting access.
# GOOGLE_CLIENT_SECRET — Private secret used server-side to exchange the authorization code
#                        for an access token. Never exposed to the browser.
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CLIENT_ID=your_google_client_id

# Web session management — used by express-session in packages/_skillet_webclient/src/api_routes/api_auth.ts.
# This secret is used to cryptographically sign the session ID cookie, preventing tampering.
# Without a valid signature, the server rejects the cookie, so an attacker cannot forge sessions.
# In production, replace with a long random string (e.g. 64+ hex chars from `openssl rand -hex 32`).
SESSION_SECRET=your_session_secret

# Marks the session cookie `secure` (HTTPS-only) and enables Express `trust proxy`.
# Defaults on when NODE_ENV=production and off otherwise, so a deploy behind HTTPS /
# a TLS-terminating reverse proxy is secure automatically once NODE_ENV=production.
# Set this only to override that default: 'true' forces secure on outside production,
# any other value forces it off in production (e.g. when reached over plain HTTP).
# Leave unset for local HTTP dev so the cookie is still sent over http://localhost.
# SESSION_COOKIE_SECURE=true

# OpenAI API key — read by the OpenAI SDK in src/libs/utils_ai.ts.
# Required when using any openai/* model. Not needed for lmstudio/* or ollama/* models,
# which hit their local servers by default. Get a key at https://platform.openai.com/api-keys.
# OPENAI_API_KEY=sk-your-openai-api-key

# Optional override: base URL for the OpenAI provider. Set this to point at an
# OpenAI-compatible proxy or gateway. Leave unset to use the OpenAI SDK default.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional override: base URL for the LMStudio provider.
# Defaults to http://localhost:1234/v1. Override to point at a remote LMStudio host.
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Optional override: base URL for the Ollama provider.
# Defaults to http://localhost:11434/v1. Override to point at a remote Ollama host.
# No API key is required; Ollama ignores the key the OpenAI SDK sends.
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional override: model used by the runner (triage + skill agents).
# Falls back to agents.header.model in the runner YAML, then to openai/gpt-4.1-nano.
# Format is '<provider>/<model>'. Supported providers (see src/libs/utils_ai.ts):
#   - openai    (needs OPENAI_API_KEY)
#   - lmstudio  (local OpenAI-compatible server, see LMSTUDIO_BASE_URL above)
#   - ollama    (local OpenAI-compatible server, see OLLAMA_BASE_URL above)
# OpenAI examples:    openai/gpt-4.1-nano (default, cheapest), openai/gpt-4.1-mini, openai/gpt-4.1
# LMStudio examples:  lmstudio/liquid/lfm2-1.2b, lmstudio/google/gemma-3-4b-it
# Ollama examples:    ollama/llama3.2, ollama/qwen3
# SKILLET_MODEL_RUNNER=openai/gpt-4.1-nano

# Optional override: model used by the LLM-as-judge eval grader.
# Same '<provider>/<model>' format as SKILLET_MODEL_RUNNER. See src/evals/eval_grader.ts.
# OpenAI examples:    openai/gpt-4.1-nano (default), openai/gpt-4.1-mini
# LMStudio examples:  lmstudio/liquid/lfm2-1.2b, lmstudio/google/gemma-3-4b-it
# Ollama examples:    ollama/llama3.2, ollama/qwen3
# SKILLET_MODEL_EVAL=openai/gpt-4.1-nano

# ─── Notifications (#238) ─────────────────────────────────────────────────────
# The job dispatcher sends an out-of-band alert when a crew needs you — a draft
# awaiting approval, or a job that blocked. Email delivery is via Resend
# (https://resend.com). When RESEND_API_KEY is unset, alerts are logged to the
# dispatcher terminal instead, so nothing is lost in local dev.
#
# RESEND_API_KEY — API key from https://resend.com/api-keys. Enables email delivery.
# RESEND_API_KEY=re_your_resend_api_key
#
# SKILLET_NOTIFY_FROM — From address for alert emails. Must be on a domain you have
# verified in Resend. The default (onboarding@resend.dev) works only in Resend test
# mode and only delivers to your own Resend account email.
# SKILLET_NOTIFY_FROM=Skilled Crew <notifications@yourdomain.com>
#
# SKILLET_PUBLIC_URL — Base URL used to build inbox links in alerts (no trailing
# slash). Defaults to http://localhost:5173.
# SKILLET_PUBLIC_URL=https://app.yourdomain.com
#
# SKILLET_NOTIFY_KINDS — Comma-separated event kinds that trigger an alert.
# Defaults to "awaiting_review,blocked". Allowed values: awaiting_review, blocked.
# SKILLET_NOTIFY_KINDS=awaiting_review,blocked
